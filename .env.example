########################################
# MedAssist AI - Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file.
########################################

# ---------- General ----------
NODE_ENV=development
APP_NAME=MedAssist AI

# ---------- Backend Server ----------
PORT=3000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173

# ---------- Frontend ----------
VITE_APP_NAME=MedAssist AI
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_SOCKET_URL=http://localhost:3000
VITE_EMERGENCY_NUMBER=1122

# ---------- PostgreSQL (legacy store — still the live data layer for
# auth/patient/doctor/appointment/report/feedback; see
# packages/backend/src/config/database.ts and scripts/migrate-data.js) ----------
DB_HOST=localhost
DB_PORT=5432
DB_USER=medassist
DB_PASSWORD=change_me_in_production
DB_NAME=medassist

# ---------- MongoDB ----------
MONGO_INITDB_ROOT_USERNAME=medassist
MONGO_INITDB_ROOT_PASSWORD=change_me_in_production
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB_NAME=medassist_ai
MONGO_URI=mongodb://medassist:change_me_in_production@localhost:27017/medassist_ai?authSource=admin

# ---------- JWT Auth ----------
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# ---------- Redis (sessions / caching / rate limiting) ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_URL=redis://:change_me_in_production@localhost:6379
REDIS_ENABLED=true
# AI symptom-prediction cache TTL (seconds)
PREDICTION_CACHE_TTL_SECONDS=3600

# ---------- Socket.io ----------
SOCKET_CORS_ORIGIN=http://localhost:5173

# ---------- Rate Limiting ----------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---------- Python AI Model Bridge ----------
# Windows + a plain python.org install: use "python" (python3.exe is a
# Microsoft Store stub there and will fail). Linux/the backend Docker
# image's venv: either name works.
PYTHON_EXECUTABLE=python
PREDICT_SCRIPT_PATH=./ml/predict.py
MODEL_PATH=./ml/disease_model.pkl
VECTORIZER_PATH=./ml/vectorizer.pkl

# ---------- File Uploads ----------
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=5242880

# ---------- Emergency Contact ----------
EMERGENCY_NUMBER=1122

# ---------- Logging ----------
LOG_LEVEL=info
LOG_DIR=./logs
